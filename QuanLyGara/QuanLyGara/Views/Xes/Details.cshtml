@model QuanLyGara.Models.Xe

@{
    ViewData["Title"] = "Hồ sơ chi tiết - " + Model.DongXe;
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;500;700;900&display=swap" rel="stylesheet">

<style>
    :root {
        --primary-color: #2b2d42;
        --accent-color: #ef233c;
        --bg-color: #f4f6f9;
        --text-color: #8d97ad;
    }

    .profile-container {
        font-family: 'Outfit', sans-serif;
        padding: 10px;
    }

    /* Tiêu đề & Nút Quay lại */
    .profile-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .page-title {
        font-size: 2.2rem;
        font-weight: 900;
        color: var(--primary-color);
        margin: 0;
    }

    .btn-outline-custom {
        border: 2px solid #e2e8f0;
        color: var(--primary-color);
        border-radius: 50px;
        padding: 8px 24px;
        font-weight: 600;
        transition: all 0.3s;
    }

        .btn-outline-custom:hover {
            background: var(--primary-color);
            color: #fff;
            border-color: var(--primary-color);
        }

    /* Khu vực Ảnh (Gallery) */
    .gallery-card {
        background: #fff;
        border-radius: 24px;
        padding: 20px;
        box-shadow: 0 10px 30px rgba(43, 45, 66, 0.04);
        height: 100%;
    }

    .main-image-container {
        width: 100%;
        height: 400px;
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 15px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        position: relative;
    }

    .main-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .main-image-container:hover .main-image {
        transform: scale(1.05);
    }

    .thumbnail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
        gap: 12px;
    }

    .thumbnail {
        height: 70px;
        border-radius: 10px;
        overflow: hidden;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all 0.2s;
    }

        .thumbnail:hover {
            border-color: var(--accent-color);
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(239, 35, 60, 0.2);
        }

        .thumbnail img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Khu vực Thông số (Specs) */
    .info-card {
        background: #fff;
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(43, 45, 66, 0.04);
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .price-tag {
        font-size: 2.5rem;
        font-weight: 900;
        color: var(--accent-color);
        margin-bottom: 5px;
    }

    .spec-item {
        display: flex;
        align-items: center;
        padding: 16px 0;
        border-bottom: 1px dashed #e2e8f0;
    }

        .spec-item:last-child {
            border-bottom: none;
        }

    .spec-icon {
        width: 45px;
        height: 45px;
        background: var(--bg-color);
        color: var(--primary-color);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-right: 15px;
    }

    .spec-label {
        font-size: 0.9rem;
        color: var(--text-color);
        font-weight: 500;
        margin-bottom: 2px;
    }

    .spec-value {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--primary-color);
    }

    /* Trạng thái */
    .status-badge {
        display: inline-block;
        padding: 8px 20px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.95rem;
        margin-top: 10px;
    }

    .status-available {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
    }

    .status-sold {
        background: rgba(239, 35, 60, 0.1);
        color: var(--accent-color);
    }

    /* Nút thao tác dưới cùng */
    .action-group {
        margin-top: auto;
        padding-top: 30px;
        display: flex;
        gap: 15px;
    }

    .btn-edit-sport {
        flex: 1;
        background: var(--primary-color);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.3s;
        text-decoration: none;
    }

        .btn-edit-sport:hover {
            background: #1a1b28;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(43, 45, 66, 0.3);
        }
</style>

<div class="profile-container">
    <div class="profile-header">
        <h2 class="page-title">HỒ SƠ XE</h2>
        <a asp-action="Index" class="btn btn-outline-custom text-decoration-none">
            <i class='bx bx-arrow-back'></i> Quay lại Kho
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="gallery-card">
                @if (Model.HinhAnhXes != null && Model.HinhAnhXes.Any())
                {
                    var anhChinh = Model.HinhAnhXes.FirstOrDefault(a => a.LaAnhChinh == true) ?? Model.HinhAnhXes.First(); var cacAnhPhu = Model.HinhAnhXes.Where(a => a.Id != anhChinh.Id).ToList();

                    <div class="main-image-container">
                        <img src="@anhChinh.DuongDanAnh" class="main-image" alt="@Model.DongXe" id="mainImageDisplay" />
                        @if (anhChinh.LaAnhChinh == true)
                        {
                            <span class="position-absolute top-0 start-0 m-3 badge bg-danger border border-light rounded-pill" style="padding: 8px 15px; font-weight: 600;">
                                <i class='bx bxs-star'></i> Ảnh
                            </span>
                        }
                    </div>

                    @if (cacAnhPhu.Any())
                    {
                        <div class="thumbnail-grid mt-3">
                            <div class="thumbnail" onclick="document.getElementById('mainImageDisplay').src='@anhChinh.DuongDanAnh'">
                                <img src="@anhChinh.DuongDanAnh" alt="Thumb" />
                            </div>
                            @foreach (var img in cacAnhPhu)
                            {
                                <div class="thumbnail" onclick="document.getElementById('mainImageDisplay').src='@img.DuongDanAnh'">
                                    <img src="@img.DuongDanAnh" alt="Thumb" />
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="main-image-container d-flex flex-column align-items-center justify-content-center" style="background: var(--bg-color);">
                        <i class='bx bx-image-alt text-muted' style="font-size: 5rem;"></i>
                        <h5 class="text-muted mt-3">Xe này chưa có hình ảnh</h5>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-5">
            <div class="info-card">
                <div>
                    <div class="text-muted fw-bold text-uppercase mb-1" style="letter-spacing: 2px;">@Model.HangXe</div>
                    <h2 class="fw-bold" style="color: var(--primary-color); font-size: 2.2rem; margin-bottom: 20px;">@Model.DongXe</h2>

                    <div class="price-tag">
                        @Model.GiaBan.ToString("N0") <span style="font-size: 1.2rem; color: var(--text-color);">VNĐ</span>
                    </div>

                    <div>
                        @if (Model.DaBan == true)
                        {
                            <div class="status-badge status-sold"><i class='bx bx-check-shield'></i> Đã Bàn Giao</div>
                        }
                        else
                        {
                            <div class="status-badge status-available"><i class='bx bxs-car-garage'></i> Sẵn Sàng Giao Dịch</div>
                        }
                    </div>
                </div>

                <div class="mt-4">
                    <div class="spec-item">
                        <div class="spec-icon"><i class='bx bx-barcode'></i></div>
                        <div>
                            <div class="spec-label">Mã số khung (VIN)</div>
                            <div class="spec-value" style="font-family: monospace;">@Model.SoKhungSoMay</div>
                        </div>
                    </div>

                    <div class="spec-item">
                        <div class="spec-icon"><i class='bx bxs-car'></i></div>
                        <div>
                            <div class="spec-label">Thương hiệu / Xuất xứ</div>
                            <div class="spec-value">@Model.HangXe</div>
                        </div>
                    </div>

                    <div class="spec-item">
                        <div class="spec-icon"><i class='bx bx-category'></i></div>
                        <div>
                            <div class="spec-label">Dòng xe</div>
                            <div class="spec-value">@Model.DongXe</div>
                        </div>
                    </div>
                </div>

                <div class="action-group">
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-edit-sport">
                        <i class='bx bxs-edit-alt'></i> Cập nhật Thông tin
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>