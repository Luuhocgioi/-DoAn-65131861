@model QuanLyGara.Models.Xe

@{
    ViewData["Title"] = "Cập Nhật Hồ Sơ Xe";
}

<style>
    :root {
        --primary-color: #2b2d42;
        --accent-color: #ef233c;
        --bg-color: #f4f6f9;
        --text-color: #8d97ad;
    }

    .form-container {
        background: #ffffff;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(43, 45, 66, 0.05);
        font-family: 'Segoe UI', sans-serif;
    }

    .form-control-custom {
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 12px 20px;
        background: #f8fafc;
        transition: border-color 0.2s;
    }

        .form-control-custom:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(43, 45, 66, 0.1);
            outline: none;
        }

    .form-label {
        font-weight: 600;
        color: var(--primary-color);
        margin-bottom: 8px;
    }

    /* Thiết kế riêng Nút gạt (Toggle Switch) cho trạng thái Đã Bán */
    .switch-wrapper {
        background: var(--bg-color);
        border-radius: 15px;
        padding: 20px;
        border: 1px dashed rgba(43, 45, 66, 0.2);
    }

    .custom-switch {
        width: 3.5rem !important;
        height: 1.8rem !important;
        cursor: pointer;
    }

        .custom-switch:checked {
            background-color: var(--accent-color) !important;
            border-color: var(--accent-color) !important;
            box-shadow: 0 0 15px rgba(239, 35, 60, 0.4);
        }

    .switch-label {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--primary-color);
        margin-left: 10px;
        margin-top: 4px;
        cursor: pointer;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold" style="color: var(--primary-color);">CHỈNH SỬA THÔNG TIN</h2>
    <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius: 50px;">
        <i class='bx bx-arrow-back'></i> Hủy & Quay lại
    </a>
</div>

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="form-container">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="Id" />

                <div class="alert alert-warning d-flex align-items-center mb-4" role="alert" style="border-radius: 12px; font-size: 14px;">
                    <i class='bx bx-info-circle fs-4 me-2'></i>
                    <div>Vui lòng kiểm tra kỹ <strong>Số khung / Số máy</strong> trước khi lưu để tránh sai lệch hồ sơ.</div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="HangXe" class="form-label">Hãng Xe</label>
                        <input asp-for="HangXe" class="form-control form-control-custom" required />
                        <span asp-validation-for="HangXe" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="DongXe" class="form-label">Dòng Xe</label>
                        <input asp-for="DongXe" class="form-control form-control-custom" required />
                        <span asp-validation-for="DongXe" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="SoKhungSoMay" class="form-label">Số Khung / Số Máy (Mã VIN)</label>
                        <input asp-for="SoKhungSoMay" class="form-control form-control-custom" style="font-family: monospace; font-weight: bold; color: var(--accent-color);" required />
                        <span asp-validation-for="SoKhungSoMay" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="GiaBan" class="form-label">Giá Niêm Yết (VNĐ)</label>
                        <input asp-for="GiaBan" class="form-control form-control-custom" type="number" required />
                        <span asp-validation-for="GiaBan" class="text-danger"></span>
                    </div>
                </div>

                <div class="switch-wrapper mt-3 mb-4">
                    <div class="form-check form-switch d-flex align-items-center">

                        <input class="form-check-input custom-switch" type="checkbox" id="DaBanSwitch" name="DaBan" value="true" @(Model.DaBan == true ? "checked" : "")>

                        <input type="hidden" name="DaBan" value="false" />

                        <label class="form-check-label switch-label" for="DaBanSwitch">
                            Xác nhận xe ĐÃ BÀN GIAO cho khách
                        </label>
                    </div>
                    <p class="text-muted mb-0 ms-5 mt-1" style="font-size: 13px;"></p>
                </div>

                <div class="text-end mt-4 pt-3 border-top">
                    <button type="submit" class="btn" style="background: var(--primary-color); color: #fff; padding: 12px 35px; border-radius: 50px; font-weight: 700; box-shadow: 0 8px 20px rgba(43, 45, 66, 0.3); transition: all 0.3s;">
                        <i class='bx bx-check-double'></i> CẬP NHẬT THÔNG TIN
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}