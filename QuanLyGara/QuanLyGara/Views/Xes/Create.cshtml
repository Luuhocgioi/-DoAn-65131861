@model QuanLyGara.Models.Xe

@{
    ViewData["Title"] = "Nhập Xe Mới";
}

<style>
    :root {
        --primary-color: #2b2d42;
        --accent-color: #ef233c;
        --bg-color: #f4f6f9;
        --text-color: #8d97ad;
    }

    .form-container {
        background: #ffffff;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(43, 45, 66, 0.05);
        font-family: 'Segoe UI', sans-serif;
    }

    /* Vùng thả ảnh cực xịn */
    .upload-area {
        border: 2px dashed rgba(43, 45, 66, 0.3);
        border-radius: 16px;
        padding: 40px 20px;
        text-align: center;
        background: var(--bg-color);
        transition: all 0.3s;
        cursor: pointer;
        position: relative;
    }

        .upload-area:hover {
            border-color: var(--accent-color);
            background: rgba(239, 35, 60, 0.05);
        }

        /* Đây chính là cái "lõi" để chọn ảnh bị ẩn đi cho đẹp */
        .upload-area input[type="file"] {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            cursor: pointer;
        }

    .upload-icon {
        font-size: 3rem;
        color: var(--primary-color);
        margin-bottom: 15px;
    }

    .form-control-custom {
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 12px 20px;
        background: #f8fafc;
        transition: border-color 0.2s;
    }

        .form-control-custom:focus {
            border-color: var(--accent-color);
            box-shadow: 0 0 0 3px rgba(239, 35, 60, 0.1);
            outline: none;
        }

    .form-label {
        font-weight: 600;
        color: var(--primary-color);
        margin-bottom: 8px;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold" style="color: var(--primary-color);">THÊM HỒ SƠ XE</h2>
    <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius: 50px;">
        <i class='bx bx-arrow-back'></i> Quay lại Kho Xe
    </a>
</div>

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="form-container">
            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="HangXe" class="form-label">Hãng Xe</label>
                        <input asp-for="HangXe" class="form-control form-control-custom" placeholder="VD: Mercedes-Benz" required />
                        <span asp-validation-for="HangXe" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="DongXe" class="form-label">Dòng Xe</label>
                        <input asp-for="DongXe" class="form-control form-control-custom" placeholder="VD: S450 Luxury" required />
                        <span asp-validation-for="DongXe" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="SoKhungSoMay" class="form-label">Số Khung / Số Máy</label>
                        <input asp-for="SoKhungSoMay" class="form-control form-control-custom" placeholder="Nhập mã VIN..." required />
                        <span asp-validation-for="SoKhungSoMay" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="GiaBan" class="form-label">Giá Niêm Yết (VNĐ)</label>
                        <input asp-for="GiaBan" class="form-control form-control-custom" type="number" required />
                        <span asp-validation-for="GiaBan" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-4 mt-2">
                    <label class="form-label">Album Ảnh Xe (Hỗ trợ tải nhiều ảnh)</label>
                    <div class="upload-area">
                        <i class='bx bx-cloud-upload upload-icon'></i>
                        <h5 style="color: var(--primary-color);">Kéo thả ảnh hoặc click vào đây để chọn</h5>
                        <p class="text-muted mb-0" style="font-size: 13px;">Hỗ trợ định dạng: JPG, PNG, WEBP (Tấm đầu tiên sẽ làm ảnh bìa)</p>

                        <input type="file" name="files" multiple accept="image/*" />
                    </div>
                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn" style="background: var(--accent-color); color: #fff; padding: 12px 35px; border-radius: 50px; font-weight: 700; box-shadow: 0 8px 20px rgba(239, 35, 60, 0.3);">
                        <i class='bx bx-save'></i> LƯU HỒ SƠ XE
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}